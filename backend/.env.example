# AXON Environment Variables — Copy this to .env and fill in your keys

# ── OKX Onchain OS API ────────────────────────────────────────────────────────
# Get at: https://www.okx.com/web3/build/docs/waas/introduction-to-dev-portal
OKX_API_KEY=your_okx_api_key
OKX_SECRET_KEY=your_okx_secret_key
OKX_PASSPHRASE=your_okx_passphrase

# ── LLM Provider (pick one) ───────────────────────────────────────────────────
# Groq (free, fastest): https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key

# Gemini (free tier): https://aistudio.google.com/apikey
# GEMINI_API_KEY=your_gemini_api_key

# OpenAI (paid): https://platform.openai.com/api-keys
# OPENAI_API_KEY=your_openai_api_key

# ── X Layer ───────────────────────────────────────────────────────────────────
XLAYER_RPC_URL=https://rpc.xlayer.tech
AXON_AGENT_WALLET=0xDb82c0d91E057E05600C8F8dc836bEb41da6df14

# ── OKLink API ────────────────────────────────────────────────────────────────
# IMPORTANT for x402: AXON uses OKLink to verify payment tx hashes on-chain
# before executing premium tools. Without this key the verification still works
# via direct RPC (eth_getTransactionReceipt) but at lower rate limits.
# Get free key at: https://www.oklink.com/api/dashboard
OKLINK_API_KEY=your_oklink_api_key

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
